<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.DeleteCard"
             Title="DeleteCard"
             Style="{StaticResource MobileMargining}">

    <VerticalStackLayout Spacing="20"
                         Padding="30"
                         HorizontalOptions="Center"
                         MaximumWidthRequest="500">

        <!-- Warning Title -->
        <Label Text="Delete Card"
               Style="{StaticResource TitleLabelStyling}"
               BackgroundColor="{StaticResource EvanRed}"
               TextColor="White"
               FontSize="22"
               HorizontalOptions="Center" />

        <!-- Warning Message -->
        <Border Stroke="#E0E0E0"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="{StaticResource EvanWhite}"
                Padding="15">

            <VerticalStackLayout Spacing="10">

                <Label Text="Are you sure you want to delete this card?"
                       FontAttributes="Bold"
                       FontSize="16"
                       TextColor="{StaticResource EvanBlack}" />

                <Label Text="This action cannot be undone."
                       FontSize="13"
                       TextColor="Gray" />

            </VerticalStackLayout>

        </Border>

        <!-- Optional: Placeholder for card preview (if you bind it later) -->
        <Border Stroke="#E0E0E0"
                StrokeShape="RoundRectangle 10"
                Padding="10"
                BackgroundColor="{StaticResource EvanWhite}">

            <Label Text="Card preview will appear here"
                   HorizontalOptions="Center"
                   TextColor="Gray"
                   FontSize="12" />

        </Border>

        <!-- Actions -->
        <VerticalStackLayout Spacing="10">

            <Button Text="Delete"
                    Style="{StaticResource Add Button}"
                    BackgroundColor="{StaticResource EvanRed}"
                    TextColor="White"
                    FontAttributes="Bold" />

            <Button Text="Cancel"
                    Style="{StaticResource Add Button}"
                    BackgroundColor="{StaticResource EvanYellow}"
                    TextColor="{StaticResource EvanBlack}" />

        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentPage>