<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.AddCard"
             Title="AddCard"
             xmlns:Header="clr-namespace:CardTrackingVang.Header"
             Style="{StaticResource MobileMargining}">

    <ScrollView>
        <ScrollView.Resources>

            <!-- Labels -->
            <Style TargetType="Label" x:Name="AddCardLabels">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="{StaticResource EvanBlack}"/>
                <Setter Property="Margin" Value="0,10,0,2"/>
            </Style>

            <!-- Inputs -->
            <Style TargetType="Entry" x:Name="AddCardEntries">
                <Setter Property="BackgroundColor" Value="{StaticResource EvanWhite}"/>
                <Setter Property="TextColor" Value="{StaticResource EvanBlack}"/>
                <Setter Property="HeightRequest" Value="45"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

        </ScrollView.Resources>

        <VerticalStackLayout Spacing="15" Padding="20">

            <Header:HeaderApp />

            <!-- Title -->
            <Label Text="Add Card"
                   Style="{StaticResource TitleLabelStyling}" />

            <!-- Photo Section -->
            <VerticalStackLayout Spacing="10">

                <Button Text="Take a photo!"
                        x:Name="TakePhotoBTN"
                        Clicked="TakePhotoBTN_Clicked"
                        Style="{StaticResource Add Button}" />

                <Border Stroke="#DDDDDD"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{StaticResource EvanWhite}"
                        HeightRequest="200"
                        Padding="5">

                    <Image x:Name="UserImage"
                           Aspect="AspectFit" />
                </Border>

            </VerticalStackLayout>

            <!-- Form Section -->
            <VerticalStackLayout Spacing="10">

                <Label Text="Card Name / Title" Style="{StaticResource AddCardLabels}" />
                <Entry x:Name="TitleEntry"
                       Style="{StaticResource AddCardEntries}"
                       Placeholder="e.g. Black Lotus" />

                <Label Text="Market Value" Style="{StaticResource AddCardLabels}" />
                <Entry x:Name="ValueEntry"
                       Style="{StaticResource AddCardEntries}"
                       Placeholder="0.00"
                       Keyboard="Numeric" />

                <Label Text="Card Type" Style="{StaticResource AddCardLabels}" />
                <Picker x:Name="CardTypePicker"
                        BackgroundColor="{StaticResource EvanWhite}"
                        Margin="0,0,0,10" />

            </VerticalStackLayout>

            <!-- Primary Action -->
            <Button Text="Add to Collection"
                    Clicked="OnAddCardClicked"
                    Style="{StaticResource Add Button}"
                    Margin="0,20,0,10" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>