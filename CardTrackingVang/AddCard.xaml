<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.AddCard"
             Title="AddCard">
    <ScrollView>
        <!-- 
    Since I know there is only one page that will use a card grid resouce,
    I think it would be fine to make all my stlying here
    please let me know if this is a bad mindset.
    -->
        <VerticalStackLayout Spacing="20" Padding="30">

            <Label Text="Add Card" 
                   FontSize="Header" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource EvanBlack}"
                   BackgroundColor="{StaticResource EvanTeal}"
                   Padding="5"
                   HorizontalOptions="Center"/>

            <VerticalStackLayout Spacing="5">
                <Label Text="Card Name / Title" FontAttributes="Bold" />
                <Entry x:Name="TitleEntry" 
                       Placeholder="e.g. Black Lotus" 
                       BackgroundColor="#F0F0F0" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Market Value" FontAttributes="Bold" />
                <Entry x:Name="ValueEntry" 
                       Placeholder="0.00" 
                       Keyboard="Numeric" />
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Card Type" FontAttributes="Bold" />
                <Picker x:Name="CardTypePicker">

                </Picker>
            </VerticalStackLayout>

            <Button Text="Add to Collection"
                    Clicked="OnAddCardClicked"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,20,0,0"
                    BackgroundColor="{StaticResource EvanTeal}"
                    TextColor="{StaticResource EvanBlack}" 
                    FontSize="20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>