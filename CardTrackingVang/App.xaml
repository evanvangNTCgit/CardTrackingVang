<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CardTrackingVang"
             xmlns:ViewModels="clr-namespace:CardTrackingVang.ViewModel"
             xmlns:CurrencyConversionBind="clr-namespace:CardTrackingVang.Converter"
             x:Class="CardTrackingVang.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="EvanBlack">#011627</Color>
            <Color x:Key="EvanWhite">#FDFFFC</Color>
            <Color x:Key="EvanTeal">#2EC4B6</Color>
            <Color x:Key="EvanRed">#E71D36</Color>
            <Color x:Key="EvanYellow">#FF9F1C</Color>
            <Color x:Key="UserBgColor">#011627</Color>

            <!-- Title Label -->
            <Style x:Key="TitleLabelStyling" TargetType="Label">
                <Setter Property="BackgroundColor" Value="{StaticResource EvanRed}" />
                <Setter Property="TextColor" Value="{StaticResource EvanWhite}" />
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Margin" Value="10,10,10,5"/>
            </Style>

            <!-- Add Button -->
            <Style x:Key="Add Button" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource EvanYellow}" />
                <Setter Property="TextColor" Value="{StaticResource EvanBlack}" />
                <Setter Property="HorizontalOptions" Value="Center"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <!-- Edit Button -->
            <Style x:Key="Edit Button" TargetType="Button" BasedOn="{StaticResource Add Button}">
                <Setter Property="BackgroundColor" Value="{StaticResource EvanRed}" />
                <Setter Property="TextColor" Value="{StaticResource EvanWhite}" />
                <Setter Property="Margin" Value="10"/>
            </Style>

            <!-- Page Styling -->
            <Style x:Key="MobileMargining" TargetType="ContentPage">
                <Setter Property="Padding" Value="{OnPlatform iOS=0, Android=0, WinUI=20}" />
                <Setter Property="BackgroundColor" Value="{DynamicResource UserBgColor}" />
            </Style>

            <Style x:Key="PokemonBg" TargetType="ContentPage">
                <Setter Property="Padding" Value="{OnPlatform iOS=0, Android=0, WinUI=20}" />
                <Setter Property="BackgroundColor" Value="{DynamicResource EvanYellow}" />
            </Style>

            <!-- Section Container -->
            <Style x:Key="CardDetailsBorder" TargetType="Border">
                <Setter Property="Margin" Value="10,5"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="BackgroundColor" Value="{StaticResource EvanWhite}"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
                <Setter Property="Stroke" Value="#DDDDDD"/>
            </Style>

            <!-- Card List Item (compact row style) -->
            <DataTemplate x:Key="CardItemTemplate" x:DataType="ViewModels:CardViewModel">
                <HorizontalStackLayout Spacing="12" Padding="12" Margin="5">
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer NumberOfTapsRequired="{OnPlatform WinUI=1, Android=2}" Tapped="TapGestureRecognizer_Tapped"/>
                    </HorizontalStackLayout.GestureRecognizers>

                    <Label Text="{Binding Title}"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="{StaticResource EvanBlack}" />

                    <Label Text="{Binding CardType.Type}"
               VerticalOptions="Center"
               BackgroundColor="{StaticResource EvanTeal}"
               TextColor="White"
               Padding="6,2"
               Margin="10,0,0,0" />
                </HorizontalStackLayout>
            </DataTemplate>

            <CurrencyConversionBind:CurrencyConversion x:Key="CurrencyConversion" />

            <!-- Card Grid Item (HOME VIEW) -->
            <DataTemplate x:Key="CardsListHomeTemplate" x:DataType="ViewModels:CardViewModel">
                <VerticalStackLayout Margin="5">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer NumberOfTapsRequired="{OnPlatform WinUI=1, Android=2}" Tapped="TapGestureRecognizer_Tapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Border Stroke="#DDDDDD"
                StrokeThickness="1"
                BackgroundColor="{StaticResource EvanWhite}"
                StrokeShape="RoundRectangle 12"
                Padding="10"
                HeightRequest="300"
                WidthRequest="{OnPlatform Android=175, WinUI=300}">

                        <Grid RowDefinitions="*,auto,auto,auto" RowSpacing="5">

                            <Image Grid.Row="0"
                       Source="{Binding GetCardImage}"
                       BackgroundColor="{StaticResource EvanYellow}"
                       HeightRequest="{OnPlatform Android=160}"
                       Aspect="AspectFit"
                       Margin="0,0,0,5"/>

                            <Label Grid.Row="1"
                       Text="{Binding Title}"
                       FontAttributes="Bold"
                       FontSize="14"
                       TextColor="{StaticResource EvanBlack}" />

                            <Label Grid.Row="2"
                       Text="{Binding Value, Converter={StaticResource CurrencyConversion}}"
                       FontSize="13"
                       TextColor="{StaticResource EvanTeal}" />

                            <Label Grid.Row="3"
                       Text="{Binding CardType.Type}"
                       FontSize="12"
                       TextColor="Gray" />

                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- User Preferences Section -->
            <Style TargetType="VerticalStackLayout" x:Key="UserPrefVertStyling">
                <Setter Property="BackgroundColor" Value="{StaticResource EvanWhite}"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Padding" Value="10"/>
            </Style>

            <Style TargetType="Label" x:Key="UserPrefLabelHeading">
                <Setter Property="HorizontalOptions" Value="Center"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>

            <Style TargetType="Label" x:Key="InfoLabel">
                <Setter Property="HorizontalOptions" Value="Center"/>
                <Setter Property="BackgroundColor" Value="{StaticResource EvanWhite}"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="TextColor" Value="{StaticResource EvanBlack}"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
