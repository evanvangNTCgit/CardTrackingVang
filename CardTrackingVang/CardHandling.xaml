<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardHandling"
             Title="CardHandling">
    <VerticalStackLayout>
        <Label Style="{StaticResource TitleLabelStyling}">Add or Delete your Cards</Label>

        <Button x:Name="AddCardBtn" Style="{StaticResource Add Button}" Text="Add a card" Clicked="AddCardBtn_Clicked"/>
    </VerticalStackLayout>
</ContentPage>