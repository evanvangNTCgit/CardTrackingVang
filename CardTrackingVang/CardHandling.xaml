<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardHandling"
                          xmlns:ViewModels ="clr-namespace:CardTrackingVang.ViewModel"
             Title="CardHandling"
             Style="{StaticResource MobileMargining}">
    <ScrollView>
    <VerticalStackLayout>
        <Label Style="{StaticResource TitleLabelStyling}">Add or Delete your Cards</Label>
            <Button x:Name="AddCardBtn" Style="{StaticResource Add Button}" Margin="10" Text="Add a card" Clicked="AddCardBtn_Clicked"/>
            <CollectionView x:Name="TestOutput" x:DataType="ViewModels:CardViewModel" ItemTemplate="{StaticResource CardItemTemplate}">
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>