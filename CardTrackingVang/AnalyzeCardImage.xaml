<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.AnalyzeCardImage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:cameraModel="clr-namespace:CommunityToolkit.Maui.Core;assembly=CommunityToolkit.Maui.Camera"
             xmlns:vm="clr-namespace:CardTrackingVang.ViewModel"
             Style="{StaticResource MobileMargining}"
             Title="AnalyzeCardImage">

    <ScrollView>
        <VerticalStackLayout Spacing="15"
                             Padding="20"
                             MaximumWidthRequest="500"
                             HorizontalOptions="Center">

            <!-- Title -->
            <Label Text="Tips For Optimal Analysis"
                   Style="{StaticResource TitleLabelStyling}"
                   HorizontalOptions="Center"
                   FontSize="22" />

            <!-- Tips Card -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Style="{StaticResource InfoLabel}"
                           Text="1. Choose a high resolution image"
                           BackgroundColor="Transparent" />

                    <Label Style="{StaticResource InfoLabel}"
                           Text="2. Image should be clear"
                           BackgroundColor="Transparent" />

                    <Label Style="{StaticResource InfoLabel}"
                           Text="3. Image should include only the card"
                           BackgroundColor="Transparent" />

                </VerticalStackLayout>
            </Border>

            <!-- Example Image -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <Image Source="pikachucard.png"
                       MaximumHeightRequest="250"
                       Aspect="AspectFit" />
            </Border>

            <!-- Loading State -->
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">

                <ActivityIndicator
                    x:Name="AiActivityIndicator"
                    x:DataType="vm:ImageRecognitionViewModel"
                    IsEnabled="{Binding IsAnalyzing}"
                    IsVisible="{Binding IsAnalyzing}"
                    IsRunning="{Binding IsAnalyzing}"
                    Color="Red"
                    HeightRequest="40"
                    WidthRequest="40" />

                <Label Text="Analyzing image..."
                       IsVisible="{Binding IsAnalyzing}"
                       TextColor="Gray"
                       FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Action Button -->
            <Button Style="{StaticResource Add Button}"
                    x:Name="SelectImageBTN"
                    Text="Pick and Analyze Image"
                    Clicked="SelectImageBTN_Clicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>