<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.AnalyzeCardImage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:cameraModel="clr-namespace:CommunityToolkit.Maui.Core;assembly=CommunityToolkit.Maui.Camera"
             xmlns:vm="clr-namespace:CardTrackingVang.ViewModel"
             Title="AnalyzeCardImage">
    <VerticalStackLayout>
        <toolkit:CameraView 
            x:Name="UserCamera"
            Grid.ColumnSpan="3"
            Grid.Row="0" 
            MaximumHeightRequest="300"/>

        <Button x:Name="Capture" Text="Capture" Clicked="Capture_Clicked"></Button>
        <Button x:Name="SelectImageBTN" Text="Pick and Analyze Image" Clicked="SelectImageBTN_Clicked"></Button>
    </VerticalStackLayout>
</ContentPage>