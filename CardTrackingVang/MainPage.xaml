<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.MainPage"
             xmlns:ViewModels ="clr-namespace:CardTrackingVang.ViewModel"
             Title="Evan's Card Tracker"
             Style="{StaticResource MobileMargining}">

    <ScrollView>
        <VerticalStackLayout>
            <Label x:Name="TitleLabel" Style="{StaticResource TitleLabelStyling}">!Welcome to Evan's Card Tracker!</Label>

            <CollectionView x:Name="TestOutput" x:DataType="ViewModels:CardViewModel" ItemTemplate="{StaticResource CardItemTemplate}" SelectionMode="Single" SelectionChanged="TestOutput_SelectionChanged">
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
