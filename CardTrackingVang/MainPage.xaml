<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.MainPage"
             xmlns:ViewModels ="clr-namespace:CardTrackingVang.ViewModel"
             xmlns:Header ="clr-namespace:CardTrackingVang.Header"
             Title="Evan's Card Tracker"
             Style="{StaticResource MobileMargining}"
             >

    <ScrollView>
        <VerticalStackLayout>
            <Header:HeaderApp></Header:HeaderApp>
            <CollectionView x:Name="TestOutput" x:DataType="ViewModels:CardViewModel" ItemTemplate="{StaticResource CardsListHomeTemplate}">
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
