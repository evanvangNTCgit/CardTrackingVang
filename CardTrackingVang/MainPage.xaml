<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.MainPage"
             xmlns:ViewModels ="clr-namespace:CardTrackingVang.ViewModel"
             xmlns:Header ="clr-namespace:CardTrackingVang.Header"
             Title="Evan's Card Tracker"
             Style="{StaticResource MobileMargining}"
             >

    <ScrollView>
        <VerticalStackLayout Spacing="10">

            <!-- Header -->
            <Header:HeaderApp />

            <!-- Content Wrapper (adds structure + centering on large screens) -->
            <VerticalStackLayout
            Padding="10,0,10,10"
            HorizontalOptions="Center"
            MaximumWidthRequest="600">

                <CollectionView
                x:Name="TestOutput"
                x:DataType="ViewModels:CardViewModel"
                ItemTemplate="{StaticResource CardsListHomeTemplate}"
                Margin="0,5,0,0" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
