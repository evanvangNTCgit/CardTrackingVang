<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.MainPage"
             Title="Evan's Card Tracker"
             Style="{StaticResource MobileMargining}">

    <ScrollView>
        <VerticalStackLayout>
            <Label x:Name="TitleLabel" Style="{StaticResource TitleLabelStyling}">!Welcome to Evan's Card Tracker!</Label>

            <CollectionView x:Name="TestOutput">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding Type}"></Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
