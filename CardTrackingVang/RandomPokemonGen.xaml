<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.RandomPokemonGen"
             Title="RandomPokemonGen"
             Style="{StaticResource MobileMargining}">
    <VerticalStackLayout>
        <Grid RowDefinitions="*,*">
            <Image Grid.Row="0" Source="pokeball.png" MaximumHeightRequest="250"></Image>
            <Button Grid.Row="2" Margin="20" Style="{StaticResource Add Button}" Text="Get a random pokemon!" x:Name="GenPokeBTN" Clicked="GenPokeBTN_Clicked"></Button>
        </Grid>
    </VerticalStackLayout>
</ContentPage>