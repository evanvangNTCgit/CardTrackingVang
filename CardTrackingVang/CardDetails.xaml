<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardDetails"
             xmlns:CurrencyConversionBind="clr-namespace:CardTrackingVang.Converter"
             Title="CardDetails"
             xmlns:Header="clr-namespace:CardTrackingVang.Header"
             Style="{StaticResource MobileMargining}">

    <ContentPage.Resources>
        <CurrencyConversionBind:CurrencyConversion x:Key="currencyBinding"/>

        <!-- Section Label -->
        <Style x:Name="CardDetailsLabels" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="Gray"/>
        </Style>

        <!-- Value Label -->
        <Style TargetType="Label" x:Key="CardDetailsValue">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextColor" Value="{StaticResource EvanBlack}"/>
        </Style>

    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="10"
                             MaximumWidthRequest="500"
                             HorizontalOptions="Center">

            <Header:HeaderApp />

            <!-- Image Section -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <Image x:Name="CardImage"
                       HeightRequest="200"
                       Aspect="AspectFit"/>
            </Border>

            <!-- Title Section -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Title" Style="{StaticResource CardDetailsLabels}" />
                    <Label Text="{Binding Title}" Style="{StaticResource CardDetailsValue}" />
                    <Button x:Name="EditTitleBtn"
                            Text="Edit Title"
                            Style="{StaticResource Edit Button}"
                            Clicked="EditTitleBtn_Clicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Value Section -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Declared Value" Style="{StaticResource CardDetailsLabels}" />
                    <Label Text="{Binding Value, Converter={StaticResource currencyBinding}}"
                           Style="{StaticResource CardDetailsValue}" />
                    <Button x:Name="EditValueBtn"
                            Text="Edit Value"
                            Style="{StaticResource Edit Button}"
                            Clicked="EditValueBtn_Clicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Type Section -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Card Type" Style="{StaticResource CardDetailsLabels}" />
                    <Label Text="{Binding CardType}" Style="{StaticResource CardDetailsValue}" />
                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="10">

                    <Button Style="{StaticResource Add Button}"
                            BackgroundColor="{StaticResource EvanRed}"
                            Text="Delete Card"
                            x:Name="DeleteCardBtn"
                            Clicked="DeleteCardBtn_Clicked" />

                    <Button Style="{StaticResource Add Button}"
                            Text="Text To Speech"
                            x:Name="TextToSpeechBTN"
                            Clicked="TextToSpeechBTN_Clicked" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>