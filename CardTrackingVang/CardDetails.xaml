<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardDetails"
             xmlns:CurrencyConversionBind="clr-namespace:CardTrackingVang.Converter"
             Title="CardDetails">
    <ContentPage.Resources>
        <CurrencyConversionBind:CurrencyConversion x:Key="currencyBinding"/>
    </ContentPage.Resources>
    <VerticalStackLayout>
        <Grid RowDefinitions="*,*,*">
            <Label Grid.Row="0" Text="{Binding Title}"/>
            <Label Grid.Row="1" Text="{Binding Value, Converter={StaticResource currencyBinding}}"/>
            <Label Grid.Row="2" Text="{Binding CardType}"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>