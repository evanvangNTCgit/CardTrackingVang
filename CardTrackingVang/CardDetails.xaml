<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardDetails"
             xmlns:CurrencyConversionBind="clr-namespace:CardTrackingVang.Converter"
             Title="CardDetails"
             Style="{StaticResource MobileMargining}">
    <ContentPage.Resources>
        <CurrencyConversionBind:CurrencyConversion x:Key="currencyBinding"/>
    </ContentPage.Resources>
    <VerticalStackLayout>
        <Grid RowDefinitions="*,*,*" ColumnDefinitions="auto, auto" HorizontalOptions="Center">
            <Label Grid.Row="0" Grid.Column="0" Text="Title:" Padding="10"></Label>
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Title}" Padding="10"/>
            <Label Grid.Row="1" Grid.Column="0" Text="Declared Value:" Padding="10"></Label>
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Value, Converter={StaticResource currencyBinding}}" Padding="10"/>
            <Label Grid.Row="2" Grid.Column="0" Text="Card Type:" Padding="10"></Label>
            <Label Grid.Row="2" Grid.Column="1" Text="{Binding CardType}" Padding="10"/>
        </Grid>
        <Button Style="{StaticResource Add Button}" BackgroundColor="{StaticResource EvanRed}" Text="Delete Card" x:Name="DeleteCardBtn" Clicked="DeleteCardBtn_Clicked"></Button>
    </VerticalStackLayout>
</ContentPage>