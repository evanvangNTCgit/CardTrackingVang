<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardTrackingVang.CardDetails"
             Title="CardDetails">
    <VerticalStackLayout>
        <Grid RowDefinitions="*,*,*">
            <Label Grid.Row="0" Text="{Binding Title}"/>
            <Label Grid.Row="1" Text="{Binding Value}"/>
            <Label Grid.Row="2" Text="{Binding CardType}"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>