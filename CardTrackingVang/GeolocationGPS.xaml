<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Syncfusion.Maui.Maps;assembly=Syncfusion.Maui.Maps"
             xmlns:vm="clr-namespace:CardTrackingVang.ViewModel"
             x:Class="CardTrackingVang.GeolocationGPS"
             Title="GeolocationGPS"
             Style="{StaticResource MobileMargining}">

    <VerticalStackLayout Spacing="15"
                         Padding="15"
                         MaximumWidthRequest="700"
                         HorizontalOptions="Center">

        <!-- Title -->
        <Label Text="GPS Map View"
               Style="{StaticResource TitleLabelStyling}"
               HorizontalOptions="Center"
               FontSize="22" />

        <!-- Status Card -->
        <Border Style="{StaticResource CardDetailsBorder}">
            <Label Text="Tap 'Locate' to fetch your current position"
                   TextColor="Gray"
                   FontSize="13"
                   HorizontalOptions="Center" />
        </Border>

        <!-- Map Container -->
        <map:SfMaps x:DataType="vm:MarkerViewModel">

            <map:SfMaps.Layer>

                <map:MapTileLayer
                        Markers="{Binding MarkerModels}"
                        x:Name="tileLayer"
                        UrlTemplate="https://tile.openstreetmap.org/{z}/{x}/{y}.png">

                    <map:MapTileLayer.MarkerTemplate>
                        <DataTemplate>
                            <Image Source="pin.png"
                                       Aspect="AspectFit"
                                       HeightRequest="12"
                                       WidthRequest="12"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                        </DataTemplate>
                    </map:MapTileLayer.MarkerTemplate>

                    <map:MapTileLayer.ZoomPanBehavior>
                        <map:MapZoomPanBehavior x:Name="zoomPanBehavior"
                                                    MaxZoomLevel="20" />
                    </map:MapTileLayer.ZoomPanBehavior>

                </map:MapTileLayer>

            </map:SfMaps.Layer>

        </map:SfMaps>
        <!-- Action Controls -->
        <Border Style="{StaticResource CardDetailsBorder}">

            <VerticalStackLayout Spacing="10">

                <Label Text="Location Controls"
                       FontAttributes="Bold"
                       TextColor="{StaticResource EvanBlack}" />

                <Button Text="Locate Current Position"
                        Style="{StaticResource Add Button}"
                        x:Name="LocateBTN"
                        Clicked="LocateBTN_Clicked" />

            </VerticalStackLayout>

        </Border>

    </VerticalStackLayout>

</ContentPage>