<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CardTrackingVang.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CardTrackingVang"
    Title="CardTrackingVang">
    <TabBar>
        <Tab Title="Cards">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>
        <Tab Title="Add Card">
            <ShellContent ContentTemplate="{DataTemplate local:AddCard}" Route="AddCard"/>
        </Tab>
        <Tab Title="Help">
            <ShellContent ContentTemplate="{DataTemplate local:Help}" Route="Help"/>
        </Tab>
    </TabBar>

</Shell>
