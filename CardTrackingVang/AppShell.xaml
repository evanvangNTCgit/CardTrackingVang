<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CardTrackingVang.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CardTrackingVang"
    Title="CardTrackingVang">
    <TabBar>
        <Tab Title="Cards" Icon="plycard.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>
        <Tab Title="Add Card" Icon="plusicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:AddCard}" Route="AddCard"/>
        </Tab>
        <Tab Title="Analyze">
            <ShellContent ContentTemplate="{DataTemplate local:AnalyzeCardImage}" Route="AnalyzeCard"/>
        </Tab>
        <Tab Title="Help" Icon="questionmarkicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:Help}" Route="Help"/>
        </Tab>
        <Tab Title="Preferences">
            <ShellContent ContentTemplate="{DataTemplate local:UserPreferences}" Route="Preferences"/>
        </Tab>
        <Tab Title="GPS">
            <ShellContent ContentTemplate="{DataTemplate local:GeolocationGPS}" Route="GPS"/>
        </Tab>
    </TabBar>

</Shell>
