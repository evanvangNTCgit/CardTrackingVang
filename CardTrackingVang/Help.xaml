<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Header="clr-namespace:CardTrackingVang.Header"
             x:Class="CardTrackingVang.Help"
             Title="Help"
             Style="{StaticResource MobileMargining}">

    <ScrollView>

        <VerticalStackLayout Spacing="20"
                             Padding="20"
                             MaximumWidthRequest="600"
                             HorizontalOptions="Center">

            <Header:HeaderApp />

            <!-- Page Title -->
            <Label Text="Help and Documentation"
                   Style="{StaticResource TitleLabelStyling}"
                   HorizontalOptions="Center"
                   FontSize="22" />

            <!-- SECTION TEMPLATE STYLE (visual hierarchy shift) -->

            <!-- Viewing -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Viewing your collection"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="The home page lists your cards. Tap a card to view details."
                           TextColor="Gray" />

                    <Label Text="Use header buttons to navigate between pages."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- Add Card -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Adding a card"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Open Add Card, enter details, then tap Add to Collection."
                           TextColor="Gray" />

                    <Label Text="Use numeric keyboard for value input."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- Analyze -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Analyzing a card"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Use a high-resolution image with minimal background."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- GPS -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="GPS coordinates"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Ensure location permissions are enabled."
                           TextColor="Gray" />

                    <Label Text="Map marker shows Coulee Cards and Gaming (Wausau)."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- PokeAPI -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="PokeAPI"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Catch a random Pokémon and add it to your collection."
                           TextColor="Gray" />

                    <Label Text="Requires internet connection and HTTPS support."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- Editing -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Editing and deleting"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Edit card details from the card details page."
                           TextColor="Gray" />

                    <Label Text="Use Delete Card to remove items permanently."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

            <!-- Troubleshooting -->
            <Border Style="{StaticResource CardDetailsBorder}">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Troubleshooting"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource EvanBlack}" />

                    <Label Text="Restart app if data does not load properly."
                           TextColor="Gray" />

                    <Label Text="Check GitHub for issue reporting."
                           TextColor="Gray" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>