<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Header="clr-namespace:CardTrackingVang.Header"
             x:Class="CardTrackingVang.UserPreferences"
             Title="UserPreferences"
             Style="{StaticResource MobileMargining}">

    <ScrollView>

        <VerticalStackLayout Spacing="20"
                             Padding="25"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="500">

            <Header:HeaderApp />

            <!-- Title -->
            <Label Text="User Preferences"
                   Style="{StaticResource TitleLabelStyling}"
                   HorizontalOptions="Center"
                   FontSize="22" />

            <!-- Settings Card -->
            <Border Style="{StaticResource CardDetailsBorder}">

                <VerticalStackLayout Spacing="15">

                    <!-- Setting Row -->
                    <HorizontalStackLayout Spacing="15"
                                           VerticalOptions="Center">

                        <VerticalStackLayout Spacing="2"
                                             HorizontalOptions="StartAndExpand">

                            <Label Text="Theme"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="{StaticResource EvanBlack}" />

                            <Label Text="Toggle light / dark mode"
                                   FontSize="12"
                                   TextColor="Gray" />

                        </VerticalStackLayout>

                        <Switch x:Name="UserThemeToggle"
                                Toggled="UserThemeToggle_Toggled"
                                HorizontalOptions="End" />

                    </HorizontalStackLayout>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>